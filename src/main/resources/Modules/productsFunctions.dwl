fun mapStock(code) = code match {
	case "VU" -> "Disponivel"
	case "VN" -> "Disponivel"
	case "VD" -> "Disponivel"
	case "IM" -> "Bloqueado"
	case "VM" -> "Bloqueado"
	else -> "Faturado"
}