	<sub-flow name="create-accounts-in-salesforce" doc:id="0c4ac43f-8b6f-4d29-9290-a6d51d311a8c" >
		<ee:transform doc:name="Account Ids" doc:id="abac80e1-1636-4270-9642-a54b7d490ffb" >
			<ee:message >
			</ee:message>
			<ee:variables >
				<ee:set-variable variableName="accountId" ><![CDATA[%dw 2.0
output application/json
---
payload.codigoCliente]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<foreach doc:name="For Each Account" doc:id="7e011cc6-1f52-40c9-9dde-16efdeec894b" collection="#[vars.accountFilter]" batchSize="200">
			<ee:transform doc:name="Map Account Payload" doc:id="5b760197-9353-402d-a398-011e469ed713" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0
var accountPayload = payload map (value, index) -> {
  "attributes": {
      "type": "Account"
  },
  "IsActive__c": value.ativo default true,
  "InternCPF__c": value.cpfCnpj,
  "ActivityCode__c": value.codigoAtividade,
  "InternEmail__c": value.email,
  "ExternalId__c": value.codigoCliente,
  "DealerNetExternalId__c": value.codigoCliente,
  "Name": value.nome,
  "CommercialName__c": value.nomeFantasia,
  "InternPhone__c": (value.telefone splitBy  "  ")[0] replace  " " with "",
  "PersonalType__c": if(value.tipoPessoa == "F") "Pessoa Fisica" else "Pessoa Jurídica",
  "BillingCountryCode": "BR",
  "TestDrive__c": null
}
output application/json
---
{
	allOrNone: false,
	records: accountPayload
}]]></ee:set-payload>
				</ee:message>
				<ee:variables >
				</ee:variables>
			</ee:transform>
			<logger level="INFO" doc:name="Logger Before Salesforce System Request " doc:id="d9998ef6-6f92-49e3-9831-3626f85bd334" message="Integration: send-assets-list-to-salesforce | Size: #[sizeOf(payload)] |  Returned Payload Model: #[payload[0]]" />
