			<logger level="INFO" doc:name="Logger After Account" doc:id="7dd32beb-69be-423f-b437-d331552fa9cc" message="#[%dw 2.0&#10;output application/json&#10;---&#10;payload map (value, index) -&gt; if(value.success == true)&#10;{&#10;    accountId: vars.accountId[(index)],&#10;    sfId: value.id&#10;}&#10;else &#10;{&#10;    accountId: vars.accountId[(index)],&#10;    description: value.errors[0].message&#10;}]" />
		</foreach>
	</sub-flow>
	<sub-flow name="create-assets-in-salesforce" doc:id="36dda9ba-19f9-45af-b38a-79d0a688fda0" >
		<ee:transform doc:name="Asset Ids" doc:id="b887b887-3ffa-4819-ba3a-7da66aa37a23" >
			<ee:message >
			</ee:message>
			<ee:variables >
				<ee:set-variable variableName="assetId" ><![CDATA[%dw 2.0
output application/json
---
payload.codigoVeiculo]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<foreach doc:name="For Each Asset" doc:id="daef2fd9-8373-4b82-a504-0fd0c040c7ee" batchSize="200">
			<ee:transform doc:name="Map Asset Payload" doc:id="27e04e66-305f-4b64-bafd-a7db85a04adf" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0
import * from Modules::productsFunctions
var assetPayload = payload map (value, index) -> {
	"attributes": {
		"type": "Asset"
	},
	"Account": {
        "DealerNetExternalId__c": value.codigoCliente
    },
    "IsActive__c": value.ativo default true,
	"ExternalId__c": value.codigoVeiculo,
	"Name": value.nomeVeiculo,
	"Chassis__c": value.chassi,
	"FullChassisNumber__c": value.chassi,
	"Type__c": "Vehicle",
	("Status": mapStock(payload.codigoEstoque) ) if(isBlank(payload.codigoEstoque)), //tratar pra enviar o status real
	"Plate__c": value.placa,
	"Model__c": value.nomeVeiculo,
	"ModelCode__c": value.codigoModeloVeiculo,
	"ModelBrand__c": value.marca,
	"LastKmImformed__c": value.km,
	"YearModel__c": value.anoModelo,
	"YearOfManufacture__c": value.anoFabricacao,
	"ColorName__c": value.corExterna,
	"Renavam__c": value.renavam,
	"NumberOfDoors__c": value.numeroPortas,
	"Combustivel__c": if (value.combustivel contains  ("HIBRIDO")) "Híbrido" 
	else if (value.combustivel contains ("NENH")) null
	else value.combustivel,
	"ProductFamilyDescription__c": value.familiaFamilia
}
output application/json
---
{
	allOrNone: false,
	records: assetPayload
}
]]></ee:set-payload>
				</ee:message>
			</ee:transform>
			<logger level="INFO" doc:name="Logger Before Salesforce System Request " doc:id="364bd0cc-d10c-45bd-acbb-d5f64d5f856a" message="Integration: send-assets-list-to-salesforce | Size: #[sizeOf(payload)] |  Returned Payload Model: #[payload[0]]" />
			<flow-ref doc:name="send-assets-to-salesforce" doc:id="b2b84ed9-0145-4b7e-a44a-cce961d03760" name="send-assets-to-salesforce" />
			<logger level="INFO" doc:name="Logger After Asset" doc:id="c5219a20-a171-45b3-8adc-6a90eb04cefa" message="#[%dw 2.0&#10;output application/json&#10;---&#10;payload map (value, index) -&gt; if(value.success == true)&#10;{&#10;    assetId: vars.assetId[(index)],&#10;    sfId: value.id&#10;}&#10;else &#10;{&#10;    assetId: vars.assetId[(index)],&#10;    description: value.errors[0].message&#10;}]" />
		</foreach>
	</sub-flow>
